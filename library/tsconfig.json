{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "moduleDetection": "force",
    "noEmit": true,
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@yarcl/config": ["./src/yarcl/yarcl.default.config.ts"],
      "@yarcl/flags":  ["./src/yarcl/flags.default.config.ts"],
      "@yarcl/i18n":   ["./src/yarcl/i18n.default.config.ts"],
      "@yarcl/env":    ["./src/yarcl/env.default.config.ts"]
    }
  },
  "include": ["src"]
}
